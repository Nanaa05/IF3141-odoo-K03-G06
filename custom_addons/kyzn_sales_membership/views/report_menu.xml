    <menuitem id="menu_kyzn_reporting_root"
              name="Reporting"
              parent="sale.sale_menu_root"
              sequence="50"
              groups="group_kyzn_sales_head,group_kyzn_finance_ar"/>

    <menuitem id="menu_kyzn_dashboard"
              name="Dashboard &amp; Analisis"
              parent="menu_kyzn_reporting_root"
              action="action_kyzn_reporting"
              sequence="10"/>
</odoo>