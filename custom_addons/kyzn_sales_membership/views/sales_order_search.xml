<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_kyzn_search" model="ir.ui.view">
        <field name="name">sale.order.kyzn.search</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <search string="Cari Order">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="cabang_tugas"/>
                <field name="membership_type_id"/>
                
                <filter string="Membership Aktif" name="active_membership" domain="[('is_active', '=', True)]"/>
                <filter string="Perlu Validasi" name="to_validate" domain="[('status_validasi', '=', 'to_validate')]"/>
                <filter string="Need Revision" name="need_revision" domain="[('status_validasi', '=', 'need_revision')]"/>
                <filter string="Validated" name="validated" domain="[('status_validasi', '=', 'validated')]"/>
                <filter string="Pending Follow-up" name="pending_followup" domain="[('follow_up_status', '=', 'pending')]"/>
                
                <separator/>
                <group expand="1" string="Group By">
                    <filter string="Sales Executive" name="group_by_sales" context="{'group_by':'user_id'}"/>
                    <filter string="Cabang" name="group_by_branch" context="{'group_by':'cabang_tugas'}"/>
                    <filter string="Membership Type" name="group_by_membership" context="{'group_by':'membership_type_id'}"/>
                    <filter string="Status Validasi" name="group_by_status" context="{'group_by':'status_validasi'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
